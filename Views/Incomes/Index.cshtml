@model IEnumerable<MoneyManager.Models.Income>

@{
    ViewData["Title"] = "Income History";
}

<div class="glass-header">
    <div class="header-content">
        <h1><i class="bi bi-wallet2"></i> Income Management</h1>
        <a asp-action="Create" class="btn btn-premium"><i class="bi bi-plus-lg"></i> Add New Income</a>
    </div>
</div>

<div class="glass-card mt-4">
    <div class="table-responsive">
        <table class="table premium-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Source</th>
                    <th>Amount</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td>@item.Date.ToShortDateString()</td>
                        <td><strong>@item.Source</strong></td>
                        <td class="text-success fw-bold">@item.Amount.ToString("C")</td>
                        <td>@item.Note</td>
                        <td class="actions-cell">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action edit" title="Edit"><i class="bi bi-pencil-square"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action delete" title="Delete"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
