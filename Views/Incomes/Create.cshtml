@model MoneyManager.Models.Income

@{
    ViewData["Title"] = "Add Income";
}

<div class="glass-header">
    <h1><i class="bi bi-plus-circle"></i> Add Income Record</h1>
</div>

<div class="glass-card mt-4">
    <form asp-action="Create" class="premium-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        
        <div class="form-group mb-3">
            <label asp-for="Source" class="form-label"></label>
            <input asp-for="Source" class="form-control" placeholder="e.g., Salary, Bonus, Freelance" />
            <span asp-validation-for="Source" class="text-danger"></span>
        </div>

        <div class="form-row">
            <div class="form-group mb-3 half">
                <label asp-for="Amount" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Amount" class="form-control" />
                </div>
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="form-group mb-3 half">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group mb-4">
            <label asp-for="Note" class="form-label"></label>
            <textarea asp-for="Note" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Note" class="text-danger"></span>
        </div>

        <div class="form-actions mt-4">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-premium">Save Record</button>
        </div>
    </form>
</div>
