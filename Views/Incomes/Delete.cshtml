@model MoneyManager.Models.Income

@{
    ViewData["Title"] = "Delete Income";
}

<div class="glass-header">
    <h1><i class="bi bi-trash"></i> Delete Income Record</h1>
    <p class="text-danger mb-0 mt-2"><i class="bi bi-exclamation-triangle"></i> Are you sure you want to delete this record? This action cannot be undone.</p>
</div>

<div class="glass-card mt-4">
    <div class="details-container mb-4">
        <div class="detail-row">
            <span class="detail-label">Source</span>
            <span class="detail-value fw-bold">@Model.Source</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Amount</span>
            <span class="detail-value text-success fw-bold">@Model.Amount.ToString("C")</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Date</span>
            <span class="detail-value">@Model.Date.ToShortDateString()</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Notes</span>
            <span class="detail-value">@(string.IsNullOrEmpty(Model.Note) ? "N/A" : Model.Note)</span>
        </div>
    </div>

    <form asp-action="Delete" class="premium-form delete-form">
        <input type="hidden" asp-for="Id" />
        <div class="form-actions mt-4">
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete Record</button>
        </div>
    </form>
</div>

<style>
    .details-container {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .detail-row:last-child {
        border-bottom: none;
    }
    .detail-label {
        font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
    }
</style>
