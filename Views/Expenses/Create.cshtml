@model MoneyManager.Models.Expense

@{
    ViewData["Title"] = "Add Expense";
}

<div class="glass-header">
    <h1><i class="bi bi-plus-circle"></i> Add Expense Record</h1>
</div>

<div class="glass-card mt-4">
    <form asp-action="Create" class="premium-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        
        <div class="form-row">
            <div class="form-group mb-3 half">
                <label asp-for="CategoryId" class="form-label">Category</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
            </div>
            <div class="form-group mb-3 half">
                <label asp-for="Amount" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">tk</span>
                    <input asp-for="Amount" class="form-control" />
                </div>
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description" class="form-label"></label>
            <input asp-for="Description" class="form-control" placeholder="e.g., Grocery at Walmart" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Date" class="form-label"></label>
            <input asp-for="Date" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>

        <div class="form-group mb-4">
            <label asp-for="Note" class="form-label"></label>
            <textarea asp-for="Note" class="form-control" rows="2"></textarea>
            <span asp-validation-for="Note" class="text-danger"></span>
        </div>

        <div class="form-actions mt-4">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-premium-danger">Save Record</button>
        </div>
    </form>
</div>
